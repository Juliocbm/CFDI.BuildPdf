@using CFDI.BuildPdf.Models
@using System.Globalization
@model CfdiNominaViewModel
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Comprobante de Nómina</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            font-size: 9px;
            margin: 15px;
        }
        .main-table, .header-table, .section-table, .footer-table, .conceptos-table, .nomina-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 8px;
        }
        .main-table td, .header-table td, .section-table td, .footer-table td, .conceptos-table td, .nomina-table td,
        .main-table th, .header-table th, .section-table th, .footer-table th, .conceptos-table th, .nomina-table th {
            border: 1px solid #ccc;
            padding: 3px;
            vertical-align: top;
        }
        .main-table th, .header-table th, .section-table th, .footer-table th, .conceptos-table th, .nomina-table th {
            text-align: left;
            background-color: #f2f2f2;
            font-weight: bold;
        }
        .no-border-table, .no-border-table td, .no-border-table th {
            border: none !important;
        }
        .section-title {
            font-weight: bold;
            font-size: 11px;
            margin-top: 10px;
            margin-bottom: 4px;
            padding-bottom: 2px;
            border-bottom: 1px solid #666;
            color: #333;
        }
        .sub-section-title {
            font-weight: bold;
            font-size: 10px;
            margin-top: 8px;
            margin-bottom: 3px;
            color: #555;
        }
        .text-right { text-align: right; }
        .text-center { text-align: center; }
        .font-small { font-size: 8px; }
        .font-very-small { font-size: 7px; }
        .qr-code img {
            width: 130px;
            height: 130px;
        }
        .sello-text {
            word-break: break-all;
            white-space: pre-wrap;
            font-size: 7px;
            max-height: 60px;
            overflow: hidden;
        }
        .logo {
            max-width: 180px;
            max-height: 90px;
        }
        .w-50 { width: 50%; }
        .w-30 { width: 30%; }
        .w-70 { width: 70%; }
        .w-25 { width: 25%; }
        .w-15 { width: 15%; }
        .w-10 { width: 10%; }
        .w-20 { width: 20%; }
        .w-80 { width: 80%; }

        .nomina-detail-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 3px;
            margin-bottom: 3px;
        }
        .nomina-detail-table th, .nomina-detail-table td {
            border: 1px solid #e0e0e0;
            padding: 2px;
            font-size: 8px;
        }
        .nomina-detail-table th {
            background-color: #f9f9f9;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Encabezado: Logo y Datos del Emisor -->
        <table class="header-table no-border-table">
            <tr>
                <td class="w-30">
                    @if (!string.IsNullOrEmpty(Model?.LogoBase64))
                    {
                        <img src="data:image/png;base64,@Model.LogoBase64" alt="Logo" class="logo" />
                    }
                </td>
                <td class="w-70 text-right">
                    <strong>@Model?.EmisorNombre</strong><br />
                    RFC: @Model?.EmisorRFC<br />
                    Régimen Fiscal: @Model?.EmisorRegimenFiscal<br />
                    Lugar de Expedición: @Model?.LugarExpedicion
                </td>
            </tr>
        </table>

        <!-- Datos del Comprobante -->
        <div class="section-title">Datos del Comprobante de Nómina</div>
        <table class="section-table">
            <tr>
                <th class="w-25">Folio Fiscal (UUID)</th>
                <td class="w-25">@Model?.UUID</td>
                <th class="w-25">Fecha y Hora de Emisión</th>
                <td class="w-25">@Model?.FechaEmision.ToString("yyyy-MM-dd HH:mm:ss")</td>
            </tr>
            <tr>
                <th>Fecha y Hora de Certificación</th>
                <td>@Model?.FechaCertificacion.ToString("yyyy-MM-dd HH:mm:ss")</td>
                <th>No. Certificado Emisor</th>
                <td>@Model?.NoCertificadoEmisor</td>
            </tr>
            <tr>
                <th>No. Certificado SAT</th>
                <td>@Model?.NoCertificadoSAT</td>
                <th>Versión CFDI</th>
                <td>@Model?.Version</td>
            </tr>
            <tr>
                <th>Serie y Folio</th>
                <td>@(!string.IsNullOrEmpty(Model?.Serie) ? Model.Serie + "-" : "")@Model?.Folio</td>
                <th>Tipo de Comprobante</th>
                <td>@Model?.TipoComprobante (@(Model?.TipoComprobante == "N" ? "Nómina" : Model?.TipoComprobante))</td>
            </tr>
        </table>

        <!-- Datos del Receptor (Empleado) -->
        <div class="section-title">Datos del Empleado</div>
        <table class="section-table">
            <tr>
                <th class="w-25">Nombre</th>
                <td class="w-75" colspan="3">@Model?.ReceptorNombre</td>
            </tr>
            <tr>
                <th class="w-25">RFC</th>
                <td class="w-25">@Model?.ReceptorRFC</td>
                <th class="w-25">CURP</th>
                <td class="w-25">@Model?.Nomina?.Receptor?.Curp</td>
            </tr>
            <tr>
                <th>Régimen Fiscal Receptor</th>
                <td>@Model?.ReceptorRegimenFiscal</td>
                <th>Uso CFDI</th>
                <td>@Model?.UsoCFDI</td>
            </tr>
            <tr>
                <th>No. Empleado</th>
                <td>@Model?.Nomina?.Receptor?.NumEmpleado</td>
                <th>No. Seguridad Social</th>
                <td>@Model?.Nomina?.Receptor?.NumSeguridadSocial</td>
            </tr>
            <tr>
                <th>Fecha Inicio Rel. Laboral</th>
                <td>@Model?.Nomina?.Receptor?.FechaInicioRelLaboral?.ToString("yyyy-MM-dd")</td>
                <th>Antigüedad</th>
                <td>@Model?.Nomina?.Receptor?.Antiguedad</td>
            </tr>
            <tr>
                <th>Tipo Contrato</th>
                <td>@Model?.Nomina?.Receptor?.TipoContrato</td>
                <th>Tipo Régimen</th>
                <td>@Model?.Nomina?.Receptor?.TipoRegimen</td>
            </tr>
            <tr>
                <th>Periodicidad Pago</th>
                <td>@Model?.Nomina?.Receptor?.PeriodicidadPago</td>
                <th>Puesto</th>
                <td>@Model?.Nomina?.Receptor?.Puesto</td>
            </tr>
            <tr>
                <th>Salario Diario Integrado</th>
                <td>@Model?.Nomina?.Receptor?.SalarioDiarioIntegrado?.ToString("C", CultureInfo.GetCultureInfo("es-MX"))</td>
                <th>Riesgo Puesto</th>
                <td>@Model?.Nomina?.Receptor?.RiesgoPuesto</td>
            </tr>
            <tr>
                <th>Salario Base Cot. Apor.</th>
                <td>@Model?.Nomina?.Receptor?.SalarioBaseCotApor?.ToString("C", CultureInfo.GetCultureInfo("es-MX"))</td>
                <th>Clave Entidad Federativa</th>
                <td>@Model?.Nomina?.Receptor?.ClaveEntFed</td>
            </tr>
        </table>

        <!-- Detalles de la Nómina -->
        <div class="section-title">Detalles del Pago de Nómina</div>
        <table class="section-table">
            <tr>
                <th class="w-25">Versión Complemento</th>
                <td class="w-25">@Model?.Nomina?.Version</td>
                <th class="w-25">Tipo Nómina</th>
                <td class="w-25">@Model?.Nomina?.TipoNomina (@(Model?.Nomina?.TipoNomina == "O" ? "Ordinaria" : "Extraordinaria"))</td>
            </tr>
            <tr>
                <th>Fecha Pago</th>
                <td>@Model?.Nomina?.FechaPago.ToString("yyyy-MM-dd")</td>
                <th>Fecha Inicial Pago</th>
                <td>@Model?.Nomina?.FechaInicialPago.ToString("yyyy-MM-dd")</td>
            </tr>
            <tr>
                <th>Fecha Final Pago</th>
                <td>@Model?.Nomina?.FechaFinalPago.ToString("yyyy-MM-dd")</td>
                <th>Num Días Pagados</th>
                <td class="text-right">@Model?.Nomina?.NumDiasPagados.ToString("N2", CultureInfo.InvariantCulture)</td>
            </tr>
            @if(Model?.Nomina?.Emisor?.RegistroPatronal != null)
            {
                <tr>
                    <th>Registro Patronal Emisor</th>
                    <td colspan="3">@Model.Nomina.Emisor.RegistroPatronal</td>
                </tr>
            }
        </table>

        <!-- Concepto del CFDI (Pago de Nómina) -->
        <div class="section-title">Concepto Principal del Comprobante</div>
        <table class="conceptos-table">
            <thead>
                <tr>
                    <th>Clave Prod/Serv</th>
                    <th>No. Ident.</th>
                    <th>Cant.</th>
                    <th>Clave Unidad</th>
                    <th>Unidad</th>
                    <th style="width:30%">Descripción</th>
                    <th class="text-right">Valor Unitario</th>
                    <th class="text-right">Importe</th>
                    <th class="text-right">Descuento</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var concepto in Model.Conceptos)
                {
                    <tr>
                        <td>@concepto.ClaveProductoServicio</td>
                        <td>@concepto.NumeroIdentificacion</td>
                        <td class="text-right">@concepto.Cantidad.ToString("N0", CultureInfo.InvariantCulture)</td>
                        <td>@concepto.ClaveUnidad</td>
                        <td>@concepto.Unidad</td>
                        <td>@concepto.Descripcion</td>
                        <td class="text-right">@concepto.ValorUnitario.ToString("C", CultureInfo.GetCultureInfo("es-MX"))</td>
                        <td class="text-right">@concepto.Importe.ToString("C", CultureInfo.GetCultureInfo("es-MX"))</td>
                        <td class="text-right">@concepto.Descuento.ToString("C", CultureInfo.GetCultureInfo("es-MX"))</td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Percepciones -->
        @if (Model.Nomina?.Percepciones?.PercepcionesDetalle?.Any() == true)
        {
            <div class="section-title">Percepciones</div>
            <table class="nomina-table">
                <thead>
                    <tr>
                        <th>Tipo</th>
                        <th>Clave</th>
                        <th>Concepto</th>
                        <th class="text-right">Importe Gravado</th>
                        <th class="text-right">Importe Exento</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Nomina.Percepciones.PercepcionesDetalle)
                    {
                        <tr>
                            <td>@p.TipoPercepcion</td>
                            <td>@p.Clave</td>
                            <td>@p.Concepto</td>
                            <td class="text-right">@p.ImporteGravado.ToString("C", CultureInfo.GetCultureInfo("es-MX"))</td>
                            <td class="text-right">@p.ImporteExento.ToString("C", CultureInfo.GetCultureInfo("es-MX"))</td>
                        </tr>
                        if (p.HorasExtra?.Any() == true)
                        {
                            <tr>
                                <td colspan="5" class="font-small" style="padding-left: 15px;">
                                    <div class="sub-section-title" style="margin-top:0; margin-bottom:2px;">Horas Extra:</div>
                                    @foreach(var he in p.HorasExtra)
                                    {
                                        <span style="display:block;">Días: @he.Dias, Tipo: @he.TipoHoras, Horas: @he.HorasExtra, Pagado: @he.ImportePagado.ToString("C", CultureInfo.GetCultureInfo("es-MX"))</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
                <tfoot>
                    @if(Model.Nomina.Percepciones.TotalSueldos.HasValue){
                        <tr><th colspan="3" class="text-right">Total Sueldos:</th><td colspan="2" class="text-right">@Model.Nomina.Percepciones.TotalSueldos?.ToString("C", CultureInfo.GetCultureInfo("es-MX"))</td></tr>
                    }
                    <tr><th colspan="3" class="text-right">Total Gravado Percepciones:</th><td colspan="2" class="text-right">@Model.Nomina.Percepciones.TotalGravado.ToString("C", CultureInfo.GetCultureInfo("es-MX"))</td></tr>
                    <tr><th colspan="3" class="text-right">Total Exento Percepciones:</th><td colspan="2" class="text-right">@Model.Nomina.Percepciones.TotalExento.ToString("C", CultureInfo.GetCultureInfo("es-MX"))</td></tr>
                </tfoot>
            </table>
        }

        <!-- Deducciones -->
        @if (Model.Nomina?.Deducciones?.DeduccionesDetalle?.Any() == true)
        {
            <div class="section-title">Deducciones</div>
            <table class="nomina-table">
                <thead>
                    <tr>
                        <th>Tipo</th>
                        <th>Clave</th>
                        <th>Concepto</th>
                        <th class="text-right">Importe</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in Model.Nomina.Deducciones.DeduccionesDetalle)
                    {
                        <tr>
                            <td>@d.TipoDeduccion</td>
                            <td>@d.Clave</td>
                            <td>@d.Concepto</td>
                            <td class="text-right">@d.Importe.ToString("C", CultureInfo.GetCultureInfo("es-MX"))</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    @if(Model.Nomina.Deducciones.TotalOtrasDeducciones.HasValue){
                        <tr><th colspan="3" class="text-right">Total Otras Deducciones:</th><td class="text-right">@Model.Nomina.Deducciones.TotalOtrasDeducciones?.ToString("C", CultureInfo.GetCultureInfo("es-MX"))</td></tr>
                    }
                    @if(Model.Nomina.Deducciones.TotalImpuestosRetenidos.HasValue){
                        <tr><th colspan="3" class="text-right">Total Impuestos Retenidos:</th><td class="text-right">@Model.Nomina.Deducciones.TotalImpuestosRetenidos?.ToString("C", CultureInfo.GetCultureInfo("es-MX"))</td></tr>
                    }
                </tfoot>
            </table>
        }

        <!-- Otros Pagos -->
        @if (Model.Nomina?.OtrosPagos?.OtrosPagosDetalle?.Any() == true)
        {
            <div class="section-title">Otros Pagos</div>
            <table class="nomina-table">
                <thead>
                    <tr>
                        <th>Tipo</th>
                        <th>Clave</th>
                        <th>Concepto</th>
                        <th class="text-right">Importe</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var op in Model.Nomina.OtrosPagos.OtrosPagosDetalle)
                    {
                        <tr>
                            <td>@op.TipoOtroPago</td>
                            <td>@op.Clave</td>
                            <td>@op.Concepto</td>
                            <td class="text-right">@op.Importe.ToString("C", CultureInfo.GetCultureInfo("es-MX"))</td>
                        </tr>
                        if (op.SubsidioAlEmpleo != null)
                        {
                            <tr>
                                 <td colspan="4" class="font-small" style="padding-left: 15px;">
                                    <div class="sub-section-title" style="margin-top:0; margin-bottom:2px;">Subsidio al Empleo:</div>
                                    <table class="nomina-detail-table no-border-table">
                                         <tbody><tr><td class="w-50">Subsidio Causado:</td><td class="text-right">@op.SubsidioAlEmpleo.SubsidioCausado.ToString("C", CultureInfo.GetCultureInfo("es-MX"))</td></tr></tbody>
                                    </table>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
                 <tfoot>
                    <tr>
                        <th colspan="3" class="text-right">Total Otros Pagos:</th>
                        <td class="text-right">@Model.Nomina.TotalOtrosPagos?.ToString("C", CultureInfo.GetCultureInfo("es-MX"))</td>
                    </tr>
                </tfoot>
            </table>
        }

        <!-- Incapacidades -->
        @if (Model.Nomina?.Incapacidades?.Any() == true)
        {
            <div class="section-title">Incapacidades</div>
            <table class="nomina-table">
                <thead>
                    <tr>
                        <th class="text-right">Días Incapacidad</th>
                        <th>Tipo Incapacidad</th>
                        <th class="text-right">Importe Monetario</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var inc in Model.Nomina.Incapacidades)
                    {
                        <tr>
                            <td class="text-right">@inc.DiasIncapacidad</td>
                            <td>@inc.TipoIncapacidad</td>
                            <td class="text-right">@inc.ImporteMonetario?.ToString("C", CultureInfo.GetCultureInfo("es-MX"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <!-- Totales del CFDI -->
        <div class="section-title">Totales Generales del Comprobante</div>
        <table class="section-table">
            <tr>
                <th class="w-20">Subtotal del Comprobante</th>
                <td class="w-30 text-right">@Model.SubTotal.ToString("C", CultureInfo.GetCultureInfo("es-MX"))</td>
                <th class="w-20">Descuento del Comprobante</th>
                <td class="w-30 text-right">@Model.Descuento.ToString("C", CultureInfo.GetCultureInfo("es-MX"))</td>
            </tr>
            <tr>
                <th colspan="3" class="text-right">TOTAL NETO PAGADO</th>
                <td class="text-right"><strong>@Model.Total.ToString("C", CultureInfo.GetCultureInfo("es-MX"))</strong></td>
            </tr>
            <tr>
                <th colspan="1">Cantidad con Letra</th>
                <td colspan="3">@Model.CantidadConLetra</td>
            </tr>
        </table>

        <!-- Sellos y QR -->
        <div class="section-title">Información Fiscal Digital</div>
        <table class="footer-table no-border-table">
            <tr>
                <td class="w-30 text-center qr-code">
                    @if (!string.IsNullOrEmpty(Model.QRCodeBase64))
                    {
                        <img src="data:image/png;base64,@Model.QRCodeBase64" alt="Código QR" />
                    }
                </td>
                <td class="w-70">
                    <div class="font-very-small">
                        <strong>Sello Digital del Emisor:</strong>
                        <p class="sello-text">@Model.SelloEmisor</p>
                        <strong>Sello Digital del SAT:</strong>
                        <p class="sello-text">@Model.SelloSAT</p>
                        <strong>Cadena Original del Complemento de Certificación Digital del SAT:</strong>
                        <p class="sello-text">@Model.CadenaOriginalSAT</p>
                    </div>
                </td>
            </tr>
        </table>

        <div class="text-center font-small" style="margin-top:15px;">
            Este documento es una representación impresa de un Comprobante Fiscal Digital por Internet de Nómina.
        </div>
    </div>
</body>
</html>
